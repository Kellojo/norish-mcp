# Norish MCP Server Environment Variables
NORISH_API_URL=https://localhost:3000
NORISH_API_KEY=your-api-key-here

# Set to "false" to disable authentication entirely (no API key required). Defaults to enabled.
MCP_AUTH_ENABLED=true

# Authentication key for the MCP server. Clients must send this as a Bearer token in the Authorization header.
# Only required when MCP_AUTH_ENABLED is true (the default).
MCP_API_KEY=change-me-to-a-random-secret

# Comma-separated list of allowed hostnames for DNS rebinding protection (e.g., "meals.mcp.nashor.cloud,localhost"). Defaults to ['meals.mcp.nashor.cloud'] if not set.
ALLOWED_HOSTS=

PORT=3001
